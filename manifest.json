{
  "manifest_version": 3,
  "name": "Keep Guppy Alive!",
  "description": "A virtual pet fish named Guppy whose bowl represents ChatGPT's water consumption. Every prompt drops his water level — keep him alive.",
  "version": "1.0",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "/images/icons/16.png",
    "32": "/images/icons/32.png",
    "48": "/images/icons/48.png",
    "128": "/images/icons/128.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/bowl.js","scripts/popup.js"],
      
      "matches": [
        "https://chatgpt.com/*"
      ],
      "css": ["styles/content.css"]
    }
  ],
  "web_accessible_resources": [
     {
       "resources": ["*.png","*.svg"],
       "matches": [
        "https://chatgpt.com/*"
      ],
       "use_dynamic_url": true
     }]
  
  
  
}
