{
  "manifest_version": 3,
  "name": "Fish bowl",
  "description": "detect water consumption in AI LLM tools",
  "version": "1.0",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_popup": "test.html"
  },

  "content_scripts": [
    {
      "js": ["scripts/test.js"],
      
      "matches": [
          "https://chatgpt.com/*"
        ],
        "css": ["styles/content.css"]
      }
    ]
    
  }
  
  // "https://claude.ai/*",
  // "https://gemini.google.com/*"